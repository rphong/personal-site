# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.wrangler/
/outputs/
/work/

# Workspace-local dependency, audit, and browser output.
/.pnpm-store/
/tmp/
/test-results/
/playwright-report/
/.worktrees/

# Blender backups and local caches; canonical .blend sources remain tracked.
*.blend1
*.blend2
*.blend@
*.blend~
/assets/blender/.cache/

# local 3D asset toolchain and intermediates
/.tools/
/.tmp/assets/
/.tmp/posters/
/assets/blender/**/*.blend1
/assets/blender/**/*.blend@
/assets/blender/**/quit.blend
/public/models/*.raw.glb
